# Entity: analytics

main: kit: entity: analytics: {

  alias: field: {}

  name: "analytics"
  op: {
    load: {
      name: "load"
      points: [
        {
          method: "GET"
          orig: "/api/stats"
          parts: [
            "api"
            "stats"
          ]
          transform: {
            req: "`reqdata`"
            res: "`body`"
          }
        }
      ]
    }
  }



}
